generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum Language {
  EN
  FR
  RW
  SW
}

enum Currency {
  USD
  EUR
  RWF
  GBP
}

enum LocationType {
  HOME
  WORK
  AIRPORT
  HOTEL
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

// NEW: who sent a message in the booking chat
enum MessageSenderType {
  ADMIN
  CUSTOMER  
  GUEST  
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String        @id @default(cuid())
  email           String        @unique
  phone           String?
  passwordHash    String?
  firstName       String?
  lastName        String?
  profilePicture  String?

  role            UserRole      @default(PASSENGER)
  status          AccountStatus @default(ACTIVE)
  isGuest         Boolean       @default(false)
  isEmailVerified Boolean       @default(false)
  lastLoginAt     DateTime?

  guestSessionId  String?       @unique
  guestExpiresAt  DateTime?

  emailVerificationToken String?
  passwordResetToken     String?
  passwordResetExpires   DateTime?

  preferredLanguage Language @default(EN)
  preferredCurrency Currency @default(USD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings        Booking[]
  savedLocations  SavedLocation[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  bookingMessages BookingMessage[]

  @@index([email])
  @@index([guestSessionId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model SavedLocation {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      LocationType @default(OTHER)
  address   String
  latitude  Float?
  longitude Float?
  isDefault Boolean      @default(false)

  airportCode String?
  terminal    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@index([airportCode])
  @@map("saved_locations")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  method       String
  url          String
  body         Json?
  status       String
  error        String?
  ipAddress    String?
  userAgent    String?
  responseTime Int
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model Booking {
  id               String        @id @default(cuid())
  bookingReference String        @unique // EVO-YYYYMMDD-XXXXX or REQ-YYYYMMDD-XXXXX

  // User association
  userId         String?
  user           User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Guest info
  guestEmail     String?
  guestName      String?
  guestPhone     String?
  guestSessionId String?

  // Trip details
  tripType      TripType
  fromLocation  String
  toLocation    String
  distance      String?
  fromCode      String?
  toCode        String?
  fromCity      String?
  toCity        String?

  // Dates & times
  departureDate DateTime
  returnDate    DateTime?
  departureTime String
  returnTime    String?

  // Passengers
  passengers       Int
  passengerDetails Json?

  // Pricing
  price    Float
  currency Currency @default(RWF)

  // Status
  status    BookingStatus @default(PENDING)

  // Admin fields
  adminNotes       String?   // internal-only notes, never shown to user
  statusReason     String?   // reason shown to user when status changes
  adminRespondedAt DateTime?
  adminRespondedBy String?

  // Long-distance request message
  requestMessage String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  cancelledAt DateTime?
  rejectedAt  DateTime?

  // Relations
  notifications Notification[]
  messages      BookingMessage[]

  @@index([bookingReference])
  @@index([userId])
  @@index([guestEmail])
  @@index([status])
  @@index([createdAt])
  @@index([departureDate])
  @@map("bookings")
}

// ─── Booking Message (chat thread per booking) ────────────────────────────────
model BookingMessage {
  id        String             @id @default(cuid())
  bookingId String
  booking   Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  senderType MessageSenderType
  senderId   String?            // User.id for ADMIN / CUSTOMER; null for GUEST
  sender     User?              @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderName String?            // display name (useful when senderId is null)

  content String
  isRead  Boolean   @default(false)
  readAt  DateTime?

  // One-time token embedded in guest reply emails
  // Allows unauthenticated reply via /booking/reply?token=...
  guestReplyToken String? @unique

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([guestReplyToken])
  @@index([createdAt])
  @@map("booking_messages")
}

model Notification {
  id        String   @id @default(cuid())
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  recipientEmail String
  recipientName  String?
  recipientType  String

  type    String
  subject String
  content String?
  sentAt  DateTime  @default(now())
  readAt  DateTime?

  status       String
  errorMessage String?

  @@index([bookingId])
  @@index([userId])
  @@index([recipientEmail])
  @@index([sentAt])
  @@map("notifications")
}

/// Singleton row (`id`: `"default"`). Per-km rates by European meteorological season (climate-based pricing).
model PricingSettings {
  id                 String   @id
  springPricePerKm   Decimal  @default(1.15) @db.Decimal(12, 4)
  summerPricePerKm   Decimal  @default(1.35) @db.Decimal(12, 4)
  autumnPricePerKm   Decimal  @default(1.15) @db.Decimal(12, 4)
  winterPricePerKm   Decimal  @default(1.05) @db.Decimal(12, 4)
  currency           Currency @default(EUR)
  updatedAt          DateTime @updatedAt

  @@map("pricing_settings")
}
