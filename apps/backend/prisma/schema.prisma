// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum Language {
  EN 
  FR 
  RW 
  SW 
}

enum Currency {
  USD
  EUR
  RWF
  GBP
}

enum LocationType {
  HOME
  WORK
  AIRPORT
  HOTEL
  OTHER
}

enum BookingStatus {
  PENDING        
  CONFIRMED   
  REJECTED       
  CANCELLED     
  COMPLETED  
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String?        
  firstName       String?
  lastName        String?
  profilePicture  String?
  
  // Account Status
  role            UserRole        @default(PASSENGER)
  status          AccountStatus   @default(ACTIVE)
  isGuest         Boolean         @default(false)
  isEmailVerified Boolean         @default(false)
  lastLoginAt     DateTime?
  
  // Guest Session Tracking
  guestSessionId  String?         @unique
  guestExpiresAt  DateTime?
  
  // Email Verification & Password Reset
  emailVerificationToken String?
  passwordResetToken String?
  passwordResetExpires DateTime?
  
  // Preferences
  preferredLanguage Language      @default(EN)
  preferredCurrency Currency      @default(USD)
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  bookings        Booking[]
  savedLocations  SavedLocation[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  
  // Indexes
  @@index([email])
  @@index([guestSessionId])
  @@index([role])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model SavedLocation {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name            String         
  type            LocationType    @default(OTHER)
  address         String
  latitude        Float?
  longitude       Float?
  isDefault       Boolean         @default(false)
  
  // For airport locations
  airportCode     String?         
  terminal        String?
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@index([airportCode])
  @@map("saved_locations")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action     String   
  method     String   
  url        String
  body       Json?   
  status     String   
  error      String?  
  ipAddress  String?
  userAgent  String?
  responseTime Int    
  
  createdAt  DateTime @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([method])
  @@index([status])
  @@map("audit_logs")
}

model Booking {
  id              String          @id @default(cuid())
  bookingReference String         @unique // Auto-generated: EVO-YYYYMMDD-XXXXX
  
  // User association
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Guest info (filled if userId is null)
  guestEmail      String?
  guestName       String?
  guestPhone      String?
  guestSessionId  String?         // To track guest sessions
  
  // Booking Details
  tripType        TripType
  fromLocation    String        
  toLocation      String        
  fromCode        String?   
  toCode          String?      
  fromCity        String?      
  toCity          String?   
  
  // Date and Time
  departureDate   DateTime
  returnDate      DateTime?
  departureTime   String          // "09:00"
  returnTime      String?
  
  // Passenger Information
  passengers      Int              // Total count
  passengerDetails Json?           // JSON array of passenger details

  // Pricing
  price           Float           // Total price
  currency        Currency        @default(RWF)
  
  // Status
  status          BookingStatus   @default(PENDING)
  adminNotes      String?         // Internal notes from admin
  
  // Admin interaction
  adminRespondedAt DateTime?
  adminRespondedBy String?        // Admin user ID who responded
  
  // Timestamps
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  confirmedAt     DateTime?       // When booking was confirmed
  cancelledAt     DateTime?       // When booking was cancelled

  // Relations
  notifications   Notification[]

  // Indexes for querying popular routes
  @@index([bookingReference])
  @@index([userId])
  @@index([guestEmail])
  @@index([status])
  @@index([createdAt])
  @@index([departureDate])
  @@index([fromCode])   
  @@index([toCode])    
  @@index([fromLocation]) 
  @@index([toLocation])  
  @@map("bookings")
}


// Notification of Admin
model Notification {
  id              String          @id @default(cuid())
  bookingId       String?
  booking         Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Recipient info
  recipientEmail  String
  recipientName   String?
  recipientType   String  
  
  // Notification details
  type            String         
  subject         String
  content         String?  
  sentAt          DateTime        @default(now())
  readAt          DateTime? 
  
  // Status
  status          String 
  errorMessage    String?
  
  @@index([bookingId])
  @@index([userId])
  @@index([recipientEmail])
  @@index([sentAt])
  @@map("notifications")
}